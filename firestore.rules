rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 1. MASTER GATE & Catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // HELPER FUNCTIONS
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      // Check for presence of email and handle null safely
      return isSignedIn() && request.auth.token.email != null && (
        request.auth.token.email.lower() == "sinkando@gmail.com" || 
        request.auth.token.email.lower() == "ingridsinkovitz@gmail.com"
      );
    }

    // Diagnostics collection for testing connectivity
    match /diagnostics/{docId} {
      allow read, write: if isSignedIn();
    }

    // Projects
    match /projects/{projectId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Services
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Testimonials
    match /testimonials/{testimonialId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Settings
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // About
    match /about/{aboutId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Media Library
    match /media_library/{mediaId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Users Roles
    match /users_roles/{email} {
      allow read: if isSignedIn() && (request.auth.token.email == email || isAdmin());
      allow write: if isAdmin();
    }

    // Backups
    match /backups/{backupId} {
      allow read, write: if isAdmin();
    }
  }
}