{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "Portfólio project containing media items (reels, images, texts)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "layoutType": { "type": "string", "enum": ["vertical", "horizontal"] },
        "audioUrl": { "type": "string" },
        "galleryThumbnail": { "type": "string" },
        "coverImage": { "type": "string" },
        "thumbnailFit": { "type": "string", "enum": ["cover", "contain"] },
        "cardBg": { "type": "string" },
        "order": { "type": "number" },
        "mediaItems": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": { "type": "string", "enum": ["image", "video", "text", "link"] },
              "url": { "type": "string" },
              "thumbnail": { "type": "string" },
              "order": { "type": "number" }
            }
          }
        }
      },
      "required": ["id", "title", "description", "layoutType", "galleryThumbnail", "coverImage", "mediaItems", "order"]
    },
    "UserRole": {
      "title": "User Role",
      "description": "RBAC for administration",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["super", "admin", "support"] },
        "assignedBy": { "type": "string" }
      },
      "required": ["email", "role"]
    },
    "Service": {
      "title": "Service",
      "description": "Offered services listed on landing page",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "items": { "type": "array", "items": { "type": "string" } },
        "order": { "type": "number" }
      },
      "required": ["id", "title", "items", "order"]
    },
    "Testimonial": {
      "title": "Testimonial",
      "description": "Client testimonials",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "author": { "type": "string" },
        "role": { "type": "string" },
        "text": { "type": "string" },
        "photoUrl": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["id", "author", "role", "text", "photoUrl", "order"]
    },
    "AboutMe": {
      "title": "About Me",
      "description": "Profile information including video and bio",
      "type": "object",
      "properties": {
        "videoUrl": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["videoUrl", "description"]
    },
    "SiteSettings": {
      "title": "Site Settings",
      "description": "Global configuration",
      "type": "object",
      "properties": {
        "whatsappNumber": { "type": "string" },
        "accentColor": { "type": "string" }
      },
      "required": ["whatsappNumber"]
    }
  },
  "firestore": {
    "projects/{projectId}": {
      "schema": "Project",
      "description": "Main projects collection"
    },
    "roles/{userId}": {
      "schema": "UserRole",
      "description": "Rbac collection"
    },
    "services/{serviceId}": {
      "schema": "Service",
      "description": "Services list"
    },
    "testimonials/{testimonialId}": {
      "schema": "Testimonial",
      "description": "Client feedback"
    },
    "settings/global": {
      "schema": "SiteSettings",
      "description": "Global app config"
    },
    "about/me": {
      "schema": "AboutMe",
      "description": "About me section content"
    }
  }
}
